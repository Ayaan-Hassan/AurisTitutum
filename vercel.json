{
  "rewrites": [
    {
      "source": "/api/append-log",
      "destination": "/api/logs?op=append"
    },
    {
      "source": "/api/get-logs",
      "destination": "/api/logs?op=get"
    },
    {
      "source": "/api/sync-logs",
      "destination": "/api/logs?op=sync"
    },
    {
      "source": "/api/auth/status",
      "destination": "/api/auth?op=status"
    },
    {
      "source": "/api/auth/disconnect",
      "destination": "/api/auth?op=disconnect"
    },
    {
      "source": "/api/auth/google",
      "destination": "/api/auth?op=google"
    },
    {
      "source": "/api/auth/google/callback",
      "destination": "/api/auth?op=callback"
    },
    {
      "source": "/api/state/get",
      "destination": "/api/state?op=get"
    },
    {
      "source": "/api/state/set",
      "destination": "/api/state?op=set"
    },
    {
      "source": "/api/push/register",
      "destination": "/api/push?op=register"
    },
    {
      "source": "/api/push/send",
      "destination": "/api/push?op=send"
    },
    {
      "source": "/api/cron/send-reminders",
      "destination": "/api/cron"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "* * * * *"
    }
  ]
}